# Defensa en profundidad: este directorio solo debe servir los assets que
# generan los servicios de media (WebP/SVG/PDF). Aunque la validación de
# subida ya rechaza MIME/extensión peligrosos, ningún archivo aquí debe
# ejecutarse nunca como script, sea cual sea el motor del servidor.
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

<FilesMatch "\.(php|phtml|phar|cgi|pl|py|sh|asp|aspx)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
