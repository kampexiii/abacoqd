# Producción (abacoqd.com): no copiar estos valores literalmente al `.env`
# real, son solo la checklist de qué cambiar respecto a los defaults de
# desarrollo de abajo. El `.env` de producción nunca se commitea.
#   APP_ENV=production
#   APP_DEBUG=false
#   APP_URL=https://abacoqd.com
#   LOG_LEVEL=warning
#   SESSION_SECURE_COOKIE=true   (no existe más abajo: añadir esta línea)
#   SMTP corporativo real (ver bloque MAIL_* más abajo, no smtp.example.com)
APP_NAME=AbacoQD
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Madrid
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Producción: sustituir MAIL_HOST, MAIL_USERNAME, MAIL_PASSWORD, MAIL_FROM_ADDRESS,
# CONTACT_NOTIFY_EMAIL y BOOKING_NOTIFY_EMAIL por los datos SMTP corporativos
# confirmados por Ábaco / Andrés. MAIL_FROM_ADDRESS debe ser una cuenta autenticada
# del dominio corporativo; el email del usuario del formulario viaja como Reply-To.
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=info@abacoqd.com
MAIL_PASSWORD=
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="info@abacoqd.com"
MAIL_FROM_NAME="AbacoQD"

CONTACT_NOTIFY_EMAIL=info@abacoqd.com
# Receptor de las notificaciones de reserva. Si se deja vacío, usa CONTACT_NOTIFY_EMAIL.
BOOKING_NOTIFY_EMAIL=info@abacoqd.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Prueba social Google Reviews (footer). Sin URL se oculta; sin rating/count solo enlace.
ABACO_GOOGLE_REVIEWS_URL=
ABACO_GOOGLE_REVIEWS_RATING=
ABACO_GOOGLE_REVIEWS_COUNT=
