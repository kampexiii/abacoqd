APP_NAME=AbacoQD
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Madrid
APP_URL=https://abacoqd.com

# Hostinger: usar PHP 8.4.x y crear el .env real en el servidor con secretos.

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u365817166_abacoqd
DB_USERNAME=u365817166_abacoqd_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=info@abacoqd.com
MAIL_PASSWORD=
MAIL_SCHEME=smtps
MAIL_FROM_ADDRESS="info@abacoqd.com"
MAIL_FROM_NAME="AbacoQD"

CONTACT_NOTIFY_EMAIL=info@abacoqd.com
BOOKING_NOTIFY_EMAIL=info@abacoqd.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Prueba social Google Reviews (footer). Sin URL se oculta; sin rating/count solo enlace.
ABACO_GOOGLE_REVIEWS_URL=
ABACO_GOOGLE_REVIEWS_RATING=
ABACO_GOOGLE_REVIEWS_COUNT=
